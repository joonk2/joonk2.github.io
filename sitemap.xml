---
layout: null
---

<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9 http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd"
        xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    {% for post in site.posts %}
    <url>
        <loc>{{ site.url }}{{ post.url }}</loc>
        {% if post.lastmod == null %}
        <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
        {% else %}
        <lastmod>{{ post.lastmod | date_to_xmlschema }}</lastmod>
        {% endif %}

        {% if post.sitemap.changefreq == null %}
        <changefreq>weekly</changefreq>
        {% else %}
        <changefreq>{{ post.sitemap.changefreq }}</changefreq>
        {% endif %}

        {% if post.sitemap.priority == null %}
        <priority>0.5</priority>
        {% else %}
        <priority>{{ post.sitemap.priority }}</priority>
        {% endif %}

    </url>
    {% endfor %}

    {%- comment -%}
      Include important non-post pages (categories/tags/archives).
      These pages are generated by jekyll-archives (Chirpy) and won't be listed if we only iterate `site.posts`.
    {%- endcomment -%}
    {% for page in site.pages %}
      {% assign u = page.url | default: "" %}

      {% if u == "/404.html" %}
        {% continue %}
      {% endif %}

      {% if u == "/robots.txt" %}
        {% continue %}
      {% endif %}

      {% if u == "/sitemap.xml" %}
        {% continue %}
      {% endif %}

      {% if u == "" %}
        {% continue %}
      {% endif %}

      {% if u contains "/assets/" %}
        {% continue %}
      {% endif %}

      {% if u contains "/norobots/" %}
        {% continue %}
      {% endif %}

      {% if u contains "/categories/" or u contains "/tags/" or u contains "/archives/" %}
    <url>
        <loc>{{ site.url }}{{ u }}</loc>
        <changefreq>weekly</changefreq>
        <priority>0.2</priority>
    </url>
      {% endif %}
    {% endfor %}
</urlset>